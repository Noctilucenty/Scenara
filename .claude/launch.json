{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "scenara-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082", "--clear"],
      "cwd": "scenara-mobile",
      "port": 8082,
      "autoPort": false
    },
    {
      "name": "scenara-backend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "venv\\Scripts\\uvicorn.exe app.main:app --reload --host 0.0.0.0 --port 8000"],
      "cwd": "scenara-backend",
      "port": 8000,
      "autoPort": false
    }
  ]
}
