{
  "buildCommand": "cd scenara-mobile && npm install && npx expo export --platform web",
  "outputDirectory": "scenara-mobile/dist",
  "installCommand": "echo 'install handled inside buildCommand'",
  "framework": null,
  "rewrites": [
    { "source": "/api/backend/:path*", "destination": "https://scenara-backend.onrender.com/:path*" },
    { "source": "/(.*)",               "destination": "/index.html"                                  }
  ]
}
