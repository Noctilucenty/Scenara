# Backend environment template. Copy to .env and fill in.

# ---------- App ----------
APP_ENV=dev          # dev | staging | production
APP_DEBUG=true

# ---------- Auth ----------
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ---------- Database ----------
# Leave blank to use local SQLite (scenara.db)
DATABASE_URL=
DB_ECHO=false

# ---------- CORS ----------
# "*" or comma-separated origins
CORS_ALLOW_ORIGINS=*

# ---------- Observability (Sentry) ----------
# Leave blank to disable. Get a DSN at https://sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
