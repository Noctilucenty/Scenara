# Frontend environment template. Copy to .env.local and fill in.
# EXPO_PUBLIC_* vars are inlined into both the web bundle and native binaries.

# Backend API URL (defaults to production Render URL when unset)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Sentry DSN for error reporting. Leave unset to disable.
# Get from https://sentry.io → Project Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# Environment tag for Sentry (production | staging | dev)
EXPO_PUBLIC_APP_ENV=dev
